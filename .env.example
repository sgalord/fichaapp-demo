# Supabase - obtén estos valores en: supabase.com > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL de tu app (en Vercel lo pone automático)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry - obtén el DSN en: sentry.io > tu proyecto > Settings > Client Keys
# Deja vacío para desactivar Sentry (por defecto desactivado)
NEXT_PUBLIC_SENTRY_DSN=
